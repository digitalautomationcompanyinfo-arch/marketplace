{
  "projects": {
    "default": "kif-khidmak-marketplace"
  },
  "hosting": {
    "public": "admin_dashboard/build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "database": {
    "rules": "backend/config/firebase-rules.json"
  },
  "storage": {
    "rules": "backend/config/firebase-storage-rules.txt"
  }
}
